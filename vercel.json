{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/react",
      "methods": ["POST"],
      "dest": "/src/index.js"
    },
    {
      "src": "/api/health",
      "methods": ["GET"],
      "dest": "/src/index.js"
    }
  ]
}
